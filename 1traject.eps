cp
clip
1.00 GC
0 579.84 1152 579.84 1152 0 3 0 0 DPLF
[     1 0 0    -1 0 579.84] CT
%%EndPageSetup
-0 -0 TX
1.00 LW
GS
0 0 TX
2400 1208 150 scaleImg
/DeviceRGB setcolorspace
